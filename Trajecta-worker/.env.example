RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F
REQUEST_EXCHANGE=telemetry.exchange
REQUEST_ROUTING_KEY=telemetry.parse
REQUEST_QUEUE=telemetry.parse
RESULTS_EXCHANGE=telemetry.exchange
RESULTS_ROUTING_KEY=telemetry.results
RESULTS_QUEUE=telemetry.results
API_BASE_URL=http://backend:8080
INTERNAL_WORKER_TOKEN=super-secret-1488-worker-token
WORKER_TOKEN_HEADER=X-Worker-Token
INTERNAL_RAW_PATH_TEMPLATE=/api/internal/v1/tasks/{taskId}/raw
HTTP_TIMEOUT_SECONDS=30
