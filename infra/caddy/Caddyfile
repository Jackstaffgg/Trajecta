{$DOMAIN} {
    tls {$ACME_EMAIL}
    encode gzip zstd

    @root path /
    redir @root /trajecta/ 308

    @base path /trajecta
    redir @base /trajecta/ 308

    handle /trajecta/api/* {
        uri strip_prefix /trajecta
        reverse_proxy backend:8080 {
            lb_try_duration 5s
            lb_try_interval 250ms
            transport http {
                dial_timeout 5s
                response_header_timeout 20s
            }
        }
    }

    handle /trajecta/ws* {
        uri strip_prefix /trajecta
        reverse_proxy backend:8080 {
            lb_try_duration 5s
            lb_try_interval 250ms
            transport http {
                dial_timeout 5s
                response_header_timeout 20s
            }
        }
    }

    handle_path /trajecta/* {
        reverse_proxy frontend:80 {
            lb_try_duration 5s
            lb_try_interval 250ms
            transport http {
                dial_timeout 5s
                response_header_timeout 20s
            }
        }
    }

    respond 404
}
