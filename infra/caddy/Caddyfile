{
    servers {
        max_header_size 16KB
        timeouts {
            read_header 10s
            read_body 30s
            write 120s
            idle 2m
        }
    }
}

localhost {
    tls internal

    route {
        reverse_proxy /api/* trajecta_backend:8080
        reverse_proxy /* trajecta_frontend:80
    }
}

{$DOMAIN} {
    tls {$ACME_EMAIL}
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }

    @root path /
    redir @root /trajecta/ 308

    @base path /trajecta
    redir @base /trajecta/ 308

    @task_create_post {
        method POST
        path /trajecta/api/v1/tasks
    }
    handle @task_create_post {
        @missing_bearer {
            not header_regexp Authorization ^Bearer\s+.+$
        }
        respond @missing_bearer 401 {
            body "Unauthorized"
        }

        request_body {
            max_size 50MB
        }

        uri strip_prefix /trajecta
        reverse_proxy backend:8080 {
            transport http {
                dial_timeout 5s
                response_header_timeout 60s
                read_timeout 120s
                write_timeout 120s
                keepalive 30s
            }
        }
    }

    handle /trajecta/api/* {
        request_body {
            max_size 50MB
        }

        uri strip_prefix /trajecta
        reverse_proxy backend:8080 {
            transport http {
                dial_timeout 5s
                response_header_timeout 60s
                read_timeout 120s
                write_timeout 120s
                keepalive 30s
            }
        }
    }

    handle /trajecta/ws* {
        uri strip_prefix /trajecta
        reverse_proxy backend:8080 {
            stream_timeout 24h
            stream_close_delay 5s
            transport http {
                dial_timeout 5s
                response_header_timeout 30s
                keepalive 30s
            }
        }
    }

    handle_path /trajecta/* {
        reverse_proxy frontend:80 {
            transport http {
                dial_timeout 5s
                response_header_timeout 30s
                read_timeout 60s
                write_timeout 60s
                keepalive 30s
            }
        }
    }

    respond 404
}
