# Domain for public HTTPS endpoint, e.g. telemetry.example.com
DOMAIN=example.com

# Email for Let's Encrypt notifications
ACME_EMAIL=admin@example.com

# App public subpath
VITE_APP_BASE_PATH=/trajecta/
VITE_API_BASE_URL=/trajecta
VITE_WS_PATH=/ws

# PostgreSQL
DB_USER=trajecta
DB_PASSWORD=change_me_strong_postgres_password

# RabbitMQ
RABBIT_USER=trajecta
RABBIT_PASS=change_me_strong_rabbit_password
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO
MINIO_USER=trajecta
MINIO_PASS=change_me_strong_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend security (MUST be strong and random)
JWT_SECRET=change_me_very_long_random_jwt_secret_at_least_64_chars
INTERNAL_WORKER_TOKEN=change_me_very_long_random_worker_token

# Worker
WORKER_REPLICAS=2
HTTP_TIMEOUT_SECONDS=30

# Backend JVM options
BACKEND_JAVA_TOOL_OPTIONS=-Xms192m -Xmx448m -XX:MaxMetaspaceSize=128m -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError


# Optional frontend build arg for Cesium
VITE_CESIUM_ION_TOKEN=

# Optional API rate limits
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
TASK_CREATE_RATE_LIMIT_MAX_ATTEMPTS=10
TASK_CREATE_RATE_LIMIT_WINDOW_SECONDS=60

OPENAI_API_KEY=
OPENAI_MODEL=llama-3.1-8b-instant
OPENAI_CHAT_URL=https://api.groq.com/openai/v1/chat/completions
OPENAI_CHAT_TIMEOUT_SECONDS=20

OWNER_USERNAME=Owner
OWNER_PASSWORD=Owner123
OWNER_MAIL=owner@ownermail.own
APP_SEED_ENABLED=true